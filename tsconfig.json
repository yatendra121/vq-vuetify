{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "allowJs": true,
        "jsx": "preserve",
        "jsxImportSource": "vue",
        "useDefineForClassFields": true,
        "lib": ["ESNext", "DOM", "DOM.Iterable"],
        "moduleResolution": "bundler",
        "strict": true,
        "resolveJsonModule": true, // Enable importing JSON modules
        "esModuleInterop": true,
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "noEmit": false,
        "rootDir": "./src",
        "outDir": "temp-types",
        "noUnusedLocals": false,
        "noUnusedParameters": true,
        "noImplicitReturns": true,
        "skipLibCheck": true, // Skip checking types of external modules
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,
        "types": ["node", "vue-router", "vuetify/components", "vue"],
        "paths": {
            "@/*": ["./src/*"]
        }
    },
    "include": ["src/index.ts", "src/integrations.ts"],
    "exclude": [
        "node_modules", // Avoid type-checking node_modules
        "dist" // Exclude built files
    ],
    "vueCompilerOptions": {
        "jsxSlots": true,
        "target": 3.5
    }
}

//"src/**/*.ts", "src/**/*.tsx", "src/**/*.vue"
